################################################################################
# KOS WL Bot — environment configuration
# Copy to .env and fill in. NEVER commit your real .env.
################################################################################

# ---------------------------------------------------------------------------
# Database (shared by bot + dashboard)
# ---------------------------------------------------------------------------
# Local: postgresql://kos:kos@localhost:5432/kos
# Docker compose default: postgresql://kos:kos@postgres:5432/kos
DATABASE_URL="postgresql://kos:kos@localhost:5432/kos"

# ---------------------------------------------------------------------------
# Discord bot
# ---------------------------------------------------------------------------
# From https://discord.com/developers/applications -> your app -> Bot -> Token
DISCORD_TOKEN="your-bot-token"
# Application (client) ID from the General Information page
DISCORD_CLIENT_ID="your-application-id"
# Optional: a guild id for INSTANT slash-command registration during dev.
# Leave empty in production to register commands globally.
DISCORD_GUILD_ID=""

# ---------------------------------------------------------------------------
# Bot behaviour
# ---------------------------------------------------------------------------
NODE_ENV="development"
LOG_LEVEL="info"                      # fatal|error|warn|info|debug|trace
PROOF_OUTPUT_DIR="./generated/proofs" # where PDF/CSV/PNG proofs are written
EMBED_REFRESH_SECONDS="30"            # live embed countdown refresh cadence
SCHEDULER_TICK_SECONDS="15"           # open/close/draw sweep cadence
SCHEDULER_BATCH_SIZE="25"             # max records per scheduler operation/tick
ENTRY_RATE_LIMIT_PER_MINUTE="8"       # per-user Enter/Leave anti-spam

# 64 hex chars (32 bytes). Generate: openssl rand -hex 32
# Enables AES-256-GCM encryption of winner wallet addresses at rest.
WALLET_ENCRYPTION_KEY=""

# ---------------------------------------------------------------------------
# Branding
# ---------------------------------------------------------------------------
KOS_BRAND_NAME="KOS WL Bot"
KOS_LOGO_URL=""                       # https URL to a PNG logo (optional)

# ---------------------------------------------------------------------------
# Internal control API (lets the dashboard trigger reroll/end with live
# Discord announcements). Bound to 127.0.0.1 by the bot.
# ---------------------------------------------------------------------------
INTERNAL_API_PORT="4000"
# Generate: openssl rand -hex 24   (min 24 chars). Shared with the dashboard.
INTERNAL_API_TOKEN=""

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
DASHBOARD_URL="http://localhost:3001" # used in proof embeds (optional)
# Where the dashboard reaches the bot's internal API:
BOT_INTERNAL_URL="http://127.0.0.1:4000"
# Simple shared-secret auth. Leave DASHBOARD_SESSION_TOKEN empty to DISABLE
# auth (only safe behind a VPN/private network). For real access control,
# set both and/or switch to Discord OAuth (see docs/SECURITY.md).
DASHBOARD_PASSWORD="change-me"
DASHBOARD_SESSION_TOKEN=""            # openssl rand -hex 32  (also signs OAuth sessions)

# --- Discord OAuth login (recommended) ---
# Developer Portal -> OAuth2 -> reset/copy the Client Secret, and add this
# redirect URL under OAuth2 -> Redirects:
#   <DASHBOARD_URL>/api/auth/discord/callback
# (locally: http://localhost:3001/api/auth/discord/callback)
DISCORD_CLIENT_SECRET=""
# Comma-separated Discord user IDs always allowed in. If this AND manager roles
# are both empty, any member of DISCORD_GUILD_ID can sign in (lock down later).
DASHBOARD_ALLOWED_USER_IDS=""

# ---------------------------------------------------------------------------
# Optional seed (packages/db: pnpm db:seed)
# ---------------------------------------------------------------------------
SEED_GUILD_ID=""
SEED_GUILD_NAME=""
SEED_MANAGER_ROLE_IDS=""              # comma-separated role ids
SEED_ANNOUNCE_CHANNEL_ID=""
SEED_PROOF_CHANNEL_ID=""
