// KOS WL Bot — database schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum RaffleStatus {
  DRAFT
  UPCOMING
  LIVE
  ENDED
  CANCELLED
}

/// How the eligible roles are combined.
/// ANY  = user needs at least one of the selected roles.
/// ALL  = user must hold every selected role.
enum RoleMatchMode {
  ANY
  ALL
}

enum WalletChain {
  ETHEREUM
  BASE
  SOLANA
  BITCOIN
}

enum LogCategory {
  RAFFLE
  ENTRY
  WINNER
  REROLL
  WALLET
  BLACKLIST
  ADMIN
  SYSTEM
}

// ---------------------------------------------------------------------------
// Core models
// ---------------------------------------------------------------------------

/// A Discord server (guild) using the bot, plus its configuration.
model Guild {
  id                       String   @id // Discord guild snowflake
  name                     String?
  iconUrl                  String?
  /// Roles allowed to run /raffle and /blacklist admin commands.
  managerRoleIds           String[] @default([])
  /// Default channel for winner announcements (overridable per raffle).
  defaultAnnounceChannelId String?
  /// Default channel for proof delivery (overridable per raffle).
  defaultProofChannelId    String?
  logChannelId             String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  raffles    Raffle[]
  blacklists Blacklist[]
  logs       Log[]

  @@map("guilds")
}

/// A Discord user seen by the bot (global identity). Also the dashboard's
/// authenticated identity once they sign in with Discord (Phase 2).
model User {
  id         String   @id // Discord user snowflake
  username   String
  globalName String?
  avatarUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // --- Dashboard auth (Phase 2, all optional so the bot is unaffected) ---
  email          String?
  /// OAuth2 tokens, encrypted at rest (AES-256-GCM, WALLET_ENCRYPTION_KEY).
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  /// KOS staff flag, seeded from SUPER_ADMIN_DISCORD_IDS on login.
  isSuperAdmin   Boolean   @default(false)
  lastLoginAt    DateTime?

  participants   Participant[]
  winners        Winner[]
  wallets        Wallet[]
  walletProfiles WalletProfile[]
  blacklists     Blacklist[]

  // Phase 2 organization relations.
  ownedOrgs   Organization[]       @relation("OrgOwner")
  memberships OrganizationMember[]

  // Phase 3: linked external accounts (X, etc).
  connectedAccounts ConnectedAccount[]
  TaskCompletion    TaskCompletion[]
  notifications     Notification[]

  /// Last time the user opened their notification feed (announcement unread
  /// counts are computed against this instead of materializing rows).
  notificationsSeenAt DateTime?

  @@map("users")
}

/// A user's self-registered wallet for a chain, reusable across raffles.
/// One address per (user, chain); updatable any time by the user.
model WalletProfile {
  id        Int         @id @default(autoincrement())
  userId    String
  chain     WalletChain
  address   String // encrypted at rest when WALLET_ENCRYPTION_KEY is set
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chain])
  @@index([userId])
  @@map("wallet_profiles")
}

/// A whitelist raffle. `id` doubles as the human-facing Raffle ID (#2345).
model Raffle {
  id            Int           @id @default(autoincrement())
  guildId       String
  projectName   String
  title         String
  description   String?
  spots         Int
  roleMatchMode RoleMatchMode @default(ANY)
  status        RaffleStatus  @default(UPCOMING)

  startAt DateTime
  endAt   DateTime

  /// Channel where the live raffle embed is posted.
  channelId         String?
  /// Message id of the live raffle embed (for live updates).
  messageId         String?
  /// Channel where the winner announcement is posted.
  announceChannelId String?
  /// Channel where the proof package is delivered.
  proofChannelId    String?

  bannerUrl   String?
  externalUrl String?

  /// Anti-alt / entry requirements (see EntryRequirements type in the bot).
  requirements Json?

  /// Whether winners should be DMed a wallet collection form.
  collectWallets Boolean       @default(true)
  walletChains   WalletChain[] @default([ETHEREUM])

  /// When true, a user must have a registered wallet (for one of walletChains)
  /// before they can enter.
  requireWallet Boolean @default(false)

  entryCount Int @default(0)

  /// When true, the live embed hides the entry count / entrant list.
  hideEntries Boolean @default(false)

  /// Who to ping when the raffle goes live: "none" | "here" | "everyone".
  startPing   String  @default("everyone")
  /// Guards against double-pinging.
  startPinged Boolean @default(false)

  /// Hex commitment of the seed used for the verifiable draw.
  drawSeed     String?
  drawSeedHash String?

  /// Dashboard-requested reroll, picked up + cleared by the bot scheduler.
  /// Shape: { mode, count?, userIds?, actorId }.
  rerollRequest     Json?
  rerollRequestedAt DateTime?

  /// Set by the dashboard after an edit; the bot re-renders the live post.
  editRequestedAt DateTime?

  createdById     String
  createdByName   String?
  createdByAvatar String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  endedAt         DateTime?
  drawnAt         DateTime?

  guild         Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  eligibleRoles RaffleRole[]
  participants  Participant[]
  winners       Winner[]
  proof         Proof?
  logs          Log[]
  RaffleTask    RaffleTask[]

  @@index([guildId, status])
  @@index([status, endAt])
  @@index([status, startAt])
  @@map("raffles")
}

/// A role that is eligible to enter a given raffle.
model RaffleRole {
  id       Int    @id @default(autoincrement())
  raffleId Int
  roleId   String
  roleName String

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)

  @@unique([raffleId, roleId])
  @@map("raffle_roles")
}

/// A single entry into a raffle.
model Participant {
  id        Int      @id @default(autoincrement())
  raffleId  Int
  userId    String
  username  String // snapshot at entry time
  enteredAt DateTime @default(now())

  // Anti-alt snapshot data captured at entry time.
  accountCreatedAt DateTime?
  joinedGuildAt    DateTime?
  flagged          Boolean   @default(false)
  flagReason       String?

  raffle Raffle  @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  winner Winner?

  @@unique([raffleId, userId])
  @@index([raffleId])
  @@map("participants")
}

/// A selected winner of a raffle.
model Winner {
  id            Int      @id @default(autoincrement())
  raffleId      Int
  userId        String
  username      String
  position      Int
  selectedAt    DateTime @default(now())
  /// True if this winner was added through a reroll.
  fromReroll    Boolean  @default(false)
  /// True if this winner was replaced by a reroll (kept for audit).
  replaced      Boolean  @default(false)
  participantId Int?     @unique

  raffle      Raffle       @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  participant Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  wallet      Wallet?

  @@index([raffleId])
  @@index([raffleId, userId])
  @@map("winners")
}

/// A wallet address submitted by a winner.
model Wallet {
  id          Int         @id @default(autoincrement())
  userId      String
  winnerId    Int?        @unique
  chain       WalletChain
  address     String
  submittedAt DateTime    @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  winner Winner? @relation(fields: [winnerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wallets")
}

/// Per-guild blacklist; blacklisted users cannot enter raffles.
model Blacklist {
  id        Int      @id @default(autoincrement())
  guildId   String
  userId    String
  reason    String?
  addedById String
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@map("blacklists")
}

/// Generated proof package for a completed raffle.
model Proof {
  id          Int      @id @default(autoincrement())
  raffleId    Int      @unique
  messageLink String?
  pdfPath     String?
  csvPath     String?
  cardPath    String?
  generatedAt DateTime @default(now())

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)

  @@map("proofs")
}

/// Audit log entry.
model Log {
  id        Int         @id @default(autoincrement())
  guildId   String
  raffleId  Int?
  actorId   String? // who performed the action (null = system)
  category  LogCategory
  action    String // e.g. RAFFLE_CREATE, ENTRY_ADD
  message   String
  metadata  Json?
  createdAt DateTime    @default(now())

  guild  Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  raffle Raffle? @relation(fields: [raffleId], references: [id], onDelete: SetNull)

  @@index([guildId, createdAt])
  @@index([raffleId])
  @@map("logs")
}

// ---------------------------------------------------------------------------
// Phase 2 — Multi-tenant platform (Organizations)
//
// All models below are additive. The bot never reads or writes them, so the
// existing single-tenant bot keeps working unchanged. Isolation is enforced in
// the dashboard by resolving Guild -> GuildConnection -> Organization.
// ---------------------------------------------------------------------------

enum SubscriptionPlan {
  FREE
  PRO
  SCALE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum OrgMemberStatus {
  INVITED
  ACTIVE
}

enum AnnouncementLevel {
  INFO
  WARNING
  CRITICAL
}

/// A community/tenant. Owns all of its resources (via connected guilds).
model Organization {
  id          String    @id @default(cuid())
  /// Vanity handle used in the dashboard URL space (/[slug]/...).
  slug        String    @unique
  name        String
  logoUrl     String?
  bannerUrl   String?
  description String?
  ownerId     String
  /// When set, the org is suspended by a KOS super-admin (access blocked).
  suspendedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner            User                 @relation("OrgOwner", fields: [ownerId], references: [id])
  members          OrganizationMember[]
  roles            OrganizationRole[]
  invites          OrganizationInvite[]
  guildConnections GuildConnection[]
  subscription     Subscription?
  auditLogs        AuditLog[]
  TaskDefinition   TaskDefinition[]

  @@index([ownerId])
  @@map("organizations")
}

/// A user's membership in an organization, with an assigned role.
model OrganizationMember {
  id             String          @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  status         OrgMemberStatus @default(ACTIVE)
  invitedById    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         OrganizationRole @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_members")
}

/// A role within an organization, carrying a set of permission strings.
model OrganizationRole {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  /// Canonical permission strings (see @kos/db permissions.ts).
  permissions    String[] @default([])
  /// Built-in roles (Owner/Admin/Moderator/Collab Manager/Viewer).
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]
  invites      OrganizationInvite[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("organization_roles")
}

/// A pending invite to join an organization (by Discord id or email).
model OrganizationInvite {
  id             String    @id @default(cuid())
  organizationId String
  discordUserId  String?
  email          String?
  roleId         String
  token          String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         OrganizationRole @relation(fields: [roleId], references: [id])

  @@index([organizationId])
  @@index([discordUserId])
  @@map("organization_invites")
}

/// Links a Discord server (guild) to an organization. A guild belongs to at
/// most one org (@unique guildId) — this is the isolation anchor.
model GuildConnection {
  id                String   @id @default(cuid())
  organizationId    String
  guildId           String   @unique
  connectedById     String
  ownershipVerified Boolean  @default(false)
  isPrimary         Boolean  @default(false)
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("guild_connections")
}

/// An organization's subscription (scaffold — every org starts FREE/ACTIVE).
model Subscription {
  id               String             @id @default(cuid())
  organizationId   String             @unique
  plan             SubscriptionPlan   @default(FREE)
  status           SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

/// Organization-scoped audit trail (distinct from the bot's per-guild Log).
model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String?
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

/// Tiny key-value store for service liveness (e.g. the bot heartbeat the
/// Super Admin health page reads). Written by the bot, read by the dashboard.
model SystemStatus {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt

  @@map("system_status")
}

/// Global feature flags (Super Admin).
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("feature_flags")
}

// ---------------------------------------------------------------------------
// Phase 3 — Universal account linking (Task Verification Engine foundation)
// ---------------------------------------------------------------------------

enum AccountProvider {
  X
  TELEGRAM
  GITHUB
}

/// An external account linked to a KOS user (X now; Telegram/GitHub reserved).
/// One external account can belong to only ONE KOS user (anti-alt), and a user
/// holds at most one account per provider.
model ConnectedAccount {
  id             String          @id @default(cuid())
  userId         String
  provider       AccountProvider
  /// Provider-side stable id (e.g. X numeric user id).
  externalId     String
  /// Display handle at link time (without the @).
  handle         String
  /// OAuth tokens, encrypted at rest (AES-256-GCM, WALLET_ENCRYPTION_KEY).
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("connected_accounts")
}

// ---------------------------------------------------------------------------
// Phase 3 S2 — Task Verification Engine
// ---------------------------------------------------------------------------

/// What a task asks the member to do. X_* verify against the linked X account
/// (link + attest on the free tier); DISCORD_* verify automatically via the
/// bot; VISIT_LINK is click + attest; MANUAL goes to the org's review queue.
enum TaskType {
  X_FOLLOW
  X_LIKE
  X_REPOST
  X_COMMENT
  DISCORD_JOIN
  DISCORD_ROLE
  VISIT_LINK
  MANUAL
}

enum CompletionStatus {
  PENDING
  VERIFIED
  REJECTED
  NEEDS_REVIEW
}

/// A reusable task built by an organization. Referenced by raffles now and
/// campaigns in S3 — build once, attach anywhere.
model TaskDefinition {
  id             String    @id @default(cuid())
  organizationId String
  type           TaskType
  title          String
  description    String?
  /// Per-type settings: { url?, xHandle?, tweetUrl?, guildId?, inviteUrl?,
  /// roleId?, roleName?, instructions? }
  config         Json?
  /// Points awarded on verification (paid out from S3).
  points         Int       @default(0)
  active         Boolean   @default(true)
  expiresAt      DateTime?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  completions  TaskCompletion[]
  raffleTasks  RaffleTask[]

  @@index([organizationId, active])
  @@map("task_definitions")
}

/// One user's completion state for one task. Evidence records how it was
/// verified (attested handle, discord role snapshot, verifier version…).
model TaskCompletion {
  id           String           @id @default(cuid())
  taskId       String
  userId       String
  status       CompletionStatus @default(PENDING)
  evidence     Json?
  verifiedAt   DateTime?
  reviewedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  task TaskDefinition @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@index([taskId, status])
  @@map("task_completions")
}

/// Attach a task to a raffle. Required tasks gate entry.
model RaffleTask {
  id       String  @id @default(cuid())
  raffleId Int
  taskId   String
  required Boolean @default(true)

  raffle Raffle         @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  task   TaskDefinition @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([raffleId, taskId])
  @@index([raffleId])
  @@map("raffle_tasks")
}

/// A personal notification (win, raffle result, system). Announcements are
/// merged into the feed at read time — they are NOT fanned out into rows.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  /// WIN | RESULT | SYSTEM
  type      String
  title     String
  body      String?
  /// Relative dashboard link (e.g. /me/history or /c/kos/raffles/12).
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

/// Announcement banner (Super Admin). Null organizationId = all orgs.
model Announcement {
  id             String            @id @default(cuid())
  title          String
  body           String
  level          AnnouncementLevel @default(INFO)
  active         Boolean           @default(true)
  /// Target a single org, or null to broadcast to every org.
  organizationId String?
  createdAt      DateTime          @default(now())

  @@index([organizationId])
  @@map("announcements")
}
