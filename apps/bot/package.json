{
  "name": "@kos/bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "test": "tsx --test src/commands/*.test.ts src/embeds/*.test.ts src/services/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@kos/db": "workspace:*",
    "@napi-rs/canvas": "^0.1.65",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "pdfkit": "^0.15.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pdfkit": "^0.13.5",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
